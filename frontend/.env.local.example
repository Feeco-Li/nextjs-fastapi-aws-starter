# Copy to .env.local — values come from CloudFormation outputs.
# Running `make deploy` auto-generates .env.local via scripts/post-deploy.sh.
# For Amplify Hosting: set these same 4 vars in
#   Amplify Console → App settings → Environment variables

NEXT_PUBLIC_AWS_REGION=us-east-1
NEXT_PUBLIC_USER_POOL_ID=us-east-1_XXXXXXXXX
NEXT_PUBLIC_USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_API_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com
